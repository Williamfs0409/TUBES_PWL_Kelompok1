{
    "$schema": "https://railway.com/railway.schema.json",
    "build": {
        "builder": "NIXPACKS"
    },
    "deploy": {
        "startCommand": "sh -c 'php artisan serve --host=0.0.0.0 --port=${PORT:-8000}'",
        "preDeployCommand": "php artisan migrate --force && php artisan db:seed --force && php artisan storage:link --force",
        "healthcheckPath": "/healthz",
        "healthcheckTimeout": 300,
        "restartPolicyType": "ON_FAILURE",
        "restartPolicyMaxRetries": 10
    }
}
